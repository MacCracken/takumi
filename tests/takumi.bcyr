}

fn bench_topo_10() {
    var pair = _chain_make(10);
    var packages = load64(pair);
    var adj = load64(pair + 8);
    var b = bench_new("resolve_build_order_10");
    bench_batch_start(b);
    var i = 0;
    while (i < 10000) {
        resolve_build_order(packages, adj);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);
    return 0;
}

fn bench_topo_100() {
    var pair = _chain_make(100);
