fn bench_create_file_list() {
    _fl_build();
    var b = bench_new("create_file_list_26_files");
    bench_batch_start(b);
    var i = 0;
    while (i < 100) {
        create_file_list("/tmp/takumi-bench-filelist");
        i = i + 1;
    }
    bench_batch_stop(b, 100);
    bench_report(b);
    _fl_tear_down();
    return 0;
}

fn bench_sha256_1kb() {
    var data = _sha_buf(1024);
    sha256_global_init();
    var b = bench_new("sha256_1kb");
    bench_batch_start(b);
    var i = 0;
    while (i < 10000) {
        sha256_hex(data, 1024);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);
    return 0;
}

fn bench_sha256_1mb() {
    var data = _sha_buf(1048576);
    sha256_global_init();
    var b = bench_new("sha256_1mb");
    bench_batch_start(b);
    var i = 0;
    while (i < 100) {
        sha256_hex(data, 1048576);
        i = i + 1;
    }
    bench_batch_stop(b, 100);
    bench_report(b);
    return 0;
}

fn main() {
    alloc_init();
    bench_parse_minimal();
    bench_parse_full();
    bench_validate();
    bench_cflags();
    bench_ldflags_dedup();
    bench_topo_10();
    bench_topo_100();
    bench_topo_300();
    bench_create_file_list();
    bench_sha256_1kb();
    bench_sha256_1mb();
    return 0;
}

var rc = main();
syscall(60, rc);
