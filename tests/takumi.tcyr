    assert_eq(_has_error(v_nover, "recipe has empty package version"), 1, "specific message");

    test_group("validate_recipe: single-component version -> warning");
    var v_ver1 = validate_recipe(recipe_new(
        pkg_new("hello", "7", "d", "L", vec_new(), 1, 0),
        _valid_src(), _valid_dep(), _valid_bld(), _valid_sec()));
    assert_eq(val_ok(v_ver1), 1, "still valid");
    assert_eq(_has_warning(v_ver1, "version may not be a valid version string (no '.' separator)"), 1, "warning present");

    test_group("validate_recipe: empty description -> warning");
