    assert_eq(vec_get(sec_hardening(recipe_security(r_alias)), 1), HF_STACK_PROTECTOR, "stack_protector -> HF_STACK_PROTECTOR");

    test_group("_parse_array_cstrs: empty and whitespace arrays");
    assert_eq(vec_len(_parse_array_cstrs(str_from("[]"))), 0, "empty array -> empty vec");
    assert_eq(vec_len(_parse_array_cstrs(str_from("[ ]"))), 0, "whitespace-only array -> empty vec");
    var single = _parse_array_cstrs(str_from("[\"one\"]"));
    assert_eq(vec_len(single), 1, "single element length");
    assert(streq(vec_get(single, 0), "one"), "single element value");

    test_group("validate_recipe: clean recipe passes with no errors or warnings");
    var v_clean = validate_recipe(_valid_recipe());
    assert_eq(val_ok(v_clean), 1, "val_ok");
    assert_eq(vec_len(val_errors(v_clean)), 0, "no errors");
    assert_eq(vec_len(val_warnings(v_clean)), 0, "no warnings");

    test_group("validate_recipe: empty name -> error");
    var v_noname = validate_recipe(recipe_new(
        pkg_new("", "1.0.0", "greeting", "MIT", vec_new(), 1, 0),
        _valid_src(), _valid_dep(), _valid_bld(), _valid_sec()));
    assert_eq(val_ok(v_noname), 0, "rejected");
    assert_eq(_has_error(v_noname, "recipe has empty package name"), 1, "specific message");

    test_group("validate_recipe: unsafe chars in name -> error");
    var v_unsafe = validate_recipe(recipe_new(
        pkg_new("bad/name", "1.0", "d", "L", vec_new(), 1, 0),
        _valid_src(), _valid_dep(), _valid_bld(), _valid_sec()));
    assert_eq(val_ok(v_unsafe), 0, "rejected");
    assert_eq(_has_error(v_unsafe, "package name contains unsafe characters (/, .., space, or backslash)"), 1, "specific message");

    test_group("validate_recipe: disallowed chars in name -> error");
    var v_atbang = validate_recipe(recipe_new(
        pkg_new("bad@name", "1.0", "d", "L", vec_new(), 1, 0),
        _valid_src(), _valid_dep(), _valid_bld(), _valid_sec()));
    assert_eq(val_ok(v_atbang), 0, "rejected");
    assert_eq(_has_error(v_atbang, "package name contains invalid characters (only A-Z, a-z, 0-9, '.', '-', '_' allowed)"), 1, "specific message");

    test_group("validate_recipe: empty version -> error");
    var v_nover = validate_recipe(recipe_new(
        pkg_new("hello", "", "d", "L", vec_new(), 1, 0),
        _valid_src(), _valid_dep(), _valid_bld(), _valid_sec()));
