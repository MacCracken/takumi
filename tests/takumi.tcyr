    test_group("recipe_parse_str: recognized hardening aliases parse");
    var sb_alias = str_builder_new();
    str_builder_add_cstr(sb_alias, "[package]\n");
    str_builder_add_cstr(sb_alias, "name = \"x\"\n");
    str_builder_add_cstr(sb_alias, "version = \"1\"\n");
    str_builder_add_cstr(sb_alias, "description = \"y\"\n");
    str_builder_add_cstr(sb_alias, "license = \"MIT\"\n\n");
