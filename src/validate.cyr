# takumi — recipe validation predicates (pure, input-only).
#
# Ported from rust-old/src/lib.rs: TakumiBuildSystem::validate_recipe
# was one monolithic function. Splitting into pure predicates gives each
# rule its own name and test surface; a future orchestrator in validate.cyr
# will compose them into the full recipe-validation routine.
#
# Inputs are cstrings. NUL is implicit (strlen stops at NUL), so the Rust
# `contains('\0')` check is unnecessary here — a cstring cannot embed NUL.
# Character classes are ASCII-only by design: package names and hashes
# must be reproducible and unambiguous. The Rust impl used
# `char::is_alphanumeric`, which accepts Unicode and would allow
# homoglyph collisions (Cyrillic "а" vs Latin "a"); narrowing to ASCII
# is an intentional improvement.

# ---------------------------------------------------------------------------
# Byte-class predicates. ASCII codepoints as decimal.
# ---------------------------------------------------------------------------

fn byte_is_digit(c) {
    if (c < 48) { return 0; }
    if (c > 57) { return 0; }
    return 1;
}

fn byte_is_alpha(c) {
    if (c >= 65) {
        if (c <= 90) { return 1; }
    }
    if (c >= 97) {
        if (c <= 122) { return 1; }
    }
    return 0;
}

fn byte_is_lower_hex(c) {
    if (byte_is_digit(c) == 1) { return 1; }
    if (c >= 97) {
        if (c <= 102) { return 1; }
    }
    return 0;
}

fn byte_is_allowed_name_char(c) {
    if (byte_is_alpha(c) == 1) { return 1; }
    if (byte_is_digit(c) == 1) { return 1; }
    if (c == 46) { return 1; }
    if (c == 45) { return 1; }
    if (c == 95) { return 1; }
    return 0;
}

# ---------------------------------------------------------------------------
# Name safety. Fatal if any of these fire.
# ---------------------------------------------------------------------------

# Any unsafe byte present: '/', ' ', '\', or a ".." substring.
# NUL is impossible in a cstring and is checked implicitly.
fn name_contains_unsafe(s) {
    var len = strlen(s);
    var i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c == 47) { return 1; }
        if (c == 32) { return 1; }
        if (c == 92) { return 1; }
        if (c == 46) {
            if (i + 1 < len) {
                if (load8(s + i + 1) == 46) { return 1; }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Returns 1 only if s is non-empty and every byte is in the allowed set.
fn name_has_only_allowed_chars(s) {
    var len = strlen(s);
    if (len == 0) { return 0; }
    var i = 0;
    while (i < len) {
        if (byte_is_allowed_name_char(load8(s + i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ---------------------------------------------------------------------------
# Source URL scheme — only plaintext http(s) download URLs are accepted.
# Scheme check is case-sensitive; recipes must use lowercase.
# ---------------------------------------------------------------------------

fn url_has_valid_scheme(s) {
    var len = strlen(s);
    if (len >= 7) {
        if (memeq(s, "http://", 7) == 1) { return 1; }
    }
    if (len >= 8) {
        if (memeq(s, "https://", 8) == 1) { return 1; }
    }
    return 0;
}

# ---------------------------------------------------------------------------
# SHA-256 digest format. Strict: exactly 64 bytes, all lowercase hex.
# ---------------------------------------------------------------------------

fn sha256_is_lowercase_hex64(s) {
    if (strlen(s) != 64) { return 0; }
    var i = 0;
    while (i < 64) {
        if (byte_is_lower_hex(load8(s + i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

# ---------------------------------------------------------------------------
# Version heuristic — warns if the version string has no '.' separator
# (e.g. "7" instead of "7.0"). Not strict semver, matches the Rust impl.
# ---------------------------------------------------------------------------

fn version_has_multiple_parts(s) {
    var len = strlen(s);
    var i = 0;
    while (i < len) {
        if (load8(s + i) == 46) { return 1; }
        i = i + 1;
    }
    return 0;
}

# ---------------------------------------------------------------------------
# validate_recipe — orchestrator.
#
# Rust's TakumiBuildSystem::validate_recipe short-circuits at the first
# fatal issue via `bail!`. This port accumulates all errors and all
# warnings in one pass so the caller can surface every problem at once
# (better UX for recipe authors). Within a single *entity* (package
# name, version, etc.) we still stop at the first error — chained
# errors on the same field just repeat the underlying problem.
#
# ValidateResult layout: { errors: vec<cstr>, warnings: vec<cstr> }.
# A recipe is accepted when `val_ok(result) == 1` (i.e. no errors).
# Warnings are advisory and don't block the build.
# ---------------------------------------------------------------------------

enum ValOff {
    VAL_ERRORS = 0;
    VAL_WARNINGS = 8;
    VAL_SIZE = 16;
}

fn val_new(errors, warnings) {
    var v = alloc(VAL_SIZE);
    store64(v + VAL_ERRORS, errors);
    store64(v + VAL_WARNINGS, warnings);
    return v;
}

fn val_errors(v) { return load64(v + VAL_ERRORS); }
fn val_warnings(v) { return load64(v + VAL_WARNINGS); }
fn val_ok(v) {
    if (vec_len(val_errors(v)) == 0) { return 1; }
    return 0;
}

# Walk a dep vec and push at most one error per entry. The errors vec
# is mutated in place; nothing else is returned.
fn _validate_deps(deps, errors) {
    var n = vec_len(deps);
    var i = 0;
    while (i < n) {
        var d = vec_get(deps, i);
        if (strlen(d) == 0) {
            vec_push(errors, "dependency name is empty");
        } elif (name_contains_unsafe(d) == 1) {
            vec_push(errors, "dependency name contains unsafe characters");
        } elif (name_has_only_allowed_chars(d) == 0) {
            vec_push(errors, "dependency name contains invalid characters");
        }
        i = i + 1;
    }
    return 0;
}

fn validate_recipe(recipe) {
    var errors = vec_new();
    var warnings = vec_new();

    var pkg = recipe_package(recipe);
    var src = recipe_source(recipe);
    var dep = recipe_depends(recipe);
    var bld = recipe_build(recipe);
    var sec = recipe_security(recipe);

    # Package name — fatal checks, first-hit wins.
    var name = pkg_name(pkg);
    if (strlen(name) == 0) {
        vec_push(errors, "recipe has empty package name");
    } elif (name_contains_unsafe(name) == 1) {
        vec_push(errors, "package name contains unsafe characters (/, .., space, or backslash)");
    } elif (name_has_only_allowed_chars(name) == 0) {
        vec_push(errors, "package name contains invalid characters (only A-Z, a-z, 0-9, '.', '-', '_' allowed)");
    }

    # Package version — fatal if empty; warn if shape looks non-semver.
    var version = pkg_version(pkg);
    if (strlen(version) == 0) {
        vec_push(errors, "recipe has empty package version");
    } elif (version_has_multiple_parts(version) == 0) {
        vec_push(warnings, "version may not be a valid version string (no '.' separator)");
    }

    # Package description / license — advisory.
    if (strlen(pkg_description(pkg)) == 0) {
        vec_push(warnings, "package description is empty");
    }
    if (strlen(pkg_license(pkg)) == 0) {
        vec_push(warnings, "package license is empty");
    }

    # Release — Rust used `u32` but warns when 0 (should start at 1).
    if (pkg_release(pkg) == 0) {
        vec_push(warnings, "release number is 0, should start at 1");
    }

    # Source URL — fatal if empty or wrong scheme.
    var url = src_url(src);
    if (strlen(url) == 0) {
        vec_push(errors, "recipe has empty source URL");
    } elif (url_has_valid_scheme(url) == 0) {
        vec_push(errors, "source URL uses an unsupported scheme; only https:// and http:// are allowed");
    }

    # Source sha256 — fatal if empty; warn if shape is wrong. The Rust
    # impl warned (not errored) on malformed hex because a too-short
    # placeholder is common during recipe drafting.
    var sha = src_sha256(src);
    if (strlen(sha) == 0) {
        vec_push(errors, "recipe has empty source sha256");
    } elif (sha256_is_lowercase_hex64(sha) == 0) {
        vec_push(warnings, "source sha256 is not a valid lowercase 64-character hex digest");
    }

    # Build steps — advisory when the recipe has no runnable phase.
    # Nested ifs rather than a 3-way || (safer given Cyrius's relaxed
    # short-circuit behavior).
    if (bld_configure(bld) == 0) {
        if (bld_make(bld) == 0) {
            if (bld_install(bld) == 0) {
                vec_push(warnings, "recipe has no build steps defined");
            }
        }
    }

    # Hardening — advisory but nearly always a mistake for a real
    # package. Maintainers who explicitly want no hardening can add
    # a stub (e.g. only `pie`) to silence.
    if (vec_len(sec_hardening(sec)) == 0) {
        vec_push(warnings, "no hardening flags specified");
    }

    _validate_deps(dep_runtime(dep), errors);
    _validate_deps(dep_build(dep), errors);

    return val_new(errors, warnings);
}
